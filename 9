#include <iostream>
using namespace std;

int main() {
    int a[] = {10,20,30,40,50,60};
    int n = 6, key = 40;
    int l = 0, r = n - 1;

    while (l <= r) {
        int mid = (l + r) / 2;

        if (a[mid] == key) {
            cout << "Found at index " << mid;
            return 0;
        }
        else if (a[mid] < key)
            l = mid + 1;
        else
            r = mid - 1;
    }

    cout << "Not Found";
    return 0;
}
