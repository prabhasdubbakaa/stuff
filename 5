#include<iostream.h>
#include<conio.h>

int a[20][20],v[20],n;

void dfs(int s)
{
    int i;
    v[s]=1;
    cout<<s<<" ";

    for(i=1;i<=n;i++)
        if(a[s][i] && !v[i])
            dfs(i);
}

void main()
{
    int i,j,s;
    clrscr();

    cout<<"Enter no. of vertices: ";
    cin>>n;

    cout<<"Enter adjacency matrix:\n";
    for(i=1;i<=n;i++)
        for(j=1;j<=n;j++)
            cin>>a[i][j];

    cout<<"Start vertex: ";
    cin>>s;

    dfs(s);

    getch();
}
