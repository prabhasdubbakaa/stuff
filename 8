#include <iostream>
#include <vector>
using namespace std;

void dfs(int u, vector<int> adj[], vector<bool>& vis) {
    vis[u] = true;
    cout << u << " ";

    for (int v : adj[u])
        if (!vis[v])
            dfs(v, adj, vis);
}

int main() {
    int n = 5;
    vector<int> adj[5];

    adj[0].push_back(1);
    adj[0].push_back(2);
    adj[1].push_back(3);
    adj[2].push_back(4);

    vector<bool> vis(n, false);
    dfs(0, adj, vis);

    return 0;
}
